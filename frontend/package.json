{
  "name": "frontend",
  "private": true,
  "version": "1.0.13",
  "description": "Gestor de Activos Institucionales IMSS",
  "author": "IMSS",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron": "electron .",
    "dist": "npm run build && electron-builder --win nsis -p always"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.3",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "tailwindcss": "^4.2.4",
    "vite": "^8.0.10"
  },
  "main": "electron/main.js",
  "build": {
    "compression": "maximum",
    "appId": "com.imss.gestoractivos",
    "productName": "Gestor Activos HW",
    "publish": {
      "provider": "generic",
      "url": "http://11.1.19.4/updates/"
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../GestorActivosHardware/bin/Release/net10.0-windows/win-x64/publish/",
        "to": "backend"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/IMSS_Logosímbolo_Blanco.png"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": true,
      "uninstallDisplayName": "Gestor Activos HW",
      "createDesktopShortcut": false,
      "createStartMenuShortcut": true,
      "shortcutName": "Gestor Activos IMSS",
      "allowElevation": true,
      "include": "electron/installer.nsh"
    }
  }
}